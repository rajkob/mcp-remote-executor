# Remote Executor MCP Server — environment config
# 1. Run: python init.py
# 2. Copy the generated key line below and save as .env

CRED_MASTER_KEY=

# API key authentication (recommended for shared/remote deployments)
# Set to a strong random string — clients must send header: X-MCP-Key: <value>
# Leave empty to disable auth (trusted local network only)
MCP_API_KEY=

# Optional overrides (defaults shown):
# MCP_HOST=0.0.0.0
# MCP_PORT=8765
# DATA_DIR=/app/data

# Ollama integration (optional — for ai_analyze / ollama_status tools)
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5:7b

# SSH connection pool and retry settings
# MAX_POOL_SIZE=50
# MAX_CONCURRENT_PER_HOST=3
# SSH_RETRY_COUNT=2
# SSH_RETRY_DELAY=2

# Monitoring alert thresholds (percentage, 0-100) — fires WEBHOOK_URL when breached
# CPU_ALERT_PCT=90
# MEM_ALERT_PCT=90
# DISK_ALERT_PCT=90

# Webhook for event notifications (command_failed, host_down, metric_alert)
# WEBHOOK_URL=https://hooks.slack.com/services/…
