# Remote Executor MCP Server — environment config
# 1. Run: python init.py
# 2. Copy the generated key line below and save as .env

CRED_MASTER_KEY=

# API key authentication (recommended for shared/remote deployments)
# Set to a strong random string — clients must send header: X-MCP-Key: <value>
# Leave empty to disable auth (trusted local network only)
MCP_API_KEY=

# Optional overrides (defaults shown):
# MCP_HOST=0.0.0.0
# MCP_PORT=8765
# DATA_DIR=/app/data
